{
  "$defs": {
    "AcceptedAnalysis": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "selection_lens": {
                "const": "tx_latency"
              }
            },
            "required": [
              "selection_lens"
            ]
          },
          "then": {
            "properties": {
              "lens_disposition": {
                "properties": {
                  "lens": {
                    "const": "tx_latency"
                  }
                },
                "required": [
                  "lens"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "selection_lens": {
                "const": "tenure_throughput"
              }
            },
            "required": [
              "selection_lens"
            ]
          },
          "then": {
            "properties": {
              "lens_disposition": {
                "properties": {
                  "lens": {
                    "const": "tenure_throughput"
                  }
                },
                "required": [
                  "lens"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "selection_lens": {
                "const": "commit_time"
              }
            },
            "required": [
              "selection_lens"
            ]
          },
          "then": {
            "properties": {
              "lens_disposition": {
                "properties": {
                  "lens": {
                    "const": "commit_time"
                  }
                },
                "required": [
                  "lens"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "lens_disposition": {
                "properties": {
                  "status": {
                    "const": "addressed"
                  }
                },
                "required": [
                  "status"
                ]
              }
            },
            "required": [
              "lens_disposition"
            ]
          },
          "then": {
            "properties": {
              "targets": {
                "minItems": 1
              }
            }
          }
        }
      ],
      "description": "Body of an accepted analysis. `status` is a literal `\"accepted\"` tag that\ndiscriminates this variant from [`RejectedAnalysis`] under the untagged\n[`Analysis`] enum.",
      "properties": {
        "family_id": {
          "description": "Family id (matches the candidate's `id`).",
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "type": "string"
        },
        "global_materiality_note": {
          "description": "Optional analyst note about cross-family relevance.",
          "type": [
            "string",
            "null"
          ]
        },
        "lens_disposition": {
          "$ref": "#/$defs/LensDisposition",
          "description": "Required disposition of the triage signal."
        },
        "schema_version": {
          "$ref": "#/$defs/SchemaVersionV2",
          "description": "Constant: 2."
        },
        "selection_lens": {
          "$ref": "#/$defs/SelectionLens",
          "description": "Carried verbatim from the candidate's `selection_lens`."
        },
        "status": {
          "$ref": "#/$defs/AcceptedStatusTag",
          "description": "Status discriminator; literal `\"accepted\"`."
        },
        "targets": {
          "description": "Concrete optimization targets the analyzer commits to. May be empty\nwhen `lens_disposition.status == NotActionable`.",
          "items": {
            "$ref": "#/$defs/AnalyzerTarget"
          },
          "type": "array"
        }
      },
      "required": [
        "schema_version",
        "family_id",
        "status",
        "selection_lens",
        "lens_disposition",
        "targets"
      ],
      "type": "object"
    },
    "AcceptedStatusTag": {
      "description": "Status discriminator carried on accepted analyses. Serializes as the\nliteral string `\"accepted\"`.",
      "oneOf": [
        {
          "const": "accepted",
          "description": "Literal `\"accepted\"`.",
          "type": "string"
        }
      ]
    },
    "AnalyzerTarget": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "consensus_breaking": {
                "const": true
              }
            },
            "required": [
              "consensus_breaking"
            ]
          },
          "then": {
            "properties": {
              "breakage_class": {
                "not": {
                  "type": "null"
                }
              },
              "consensus_writeup": {
                "not": {
                  "type": "null"
                }
              },
              "poc_implementable": {
                "not": {
                  "type": "null"
                }
              }
            },
            "required": [
              "breakage_class",
              "poc_implementable",
              "consensus_writeup"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "poc_implementable": {
                "const": true
              }
            },
            "required": [
              "poc_implementable"
            ]
          },
          "then": {
            "properties": {
              "poc_test_scope": {
                "allOf": [
                  {
                    "not": {
                      "type": "null"
                    }
                  },
                  {
                    "minItems": 1
                  }
                ]
              }
            },
            "required": [
              "poc_test_scope"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "breakage_class": {
                "const": "block_validation"
              }
            },
            "required": [
              "breakage_class"
            ]
          },
          "then": {
            "properties": {
              "poc_implementable": {
                "const": false
              }
            }
          }
        },
        {
          "if": {
            "not": {
              "properties": {
                "poc_implementable": {
                  "const": true
                }
              },
              "required": [
                "poc_implementable"
              ]
            }
          },
          "then": {
            "not": {
              "required": [
                "poc_test_scope"
              ]
            }
          }
        },
        {
          "if": {
            "not": {
              "properties": {
                "consensus_breaking": {
                  "const": true
                }
              },
              "required": [
                "consensus_breaking"
              ]
            }
          },
          "then": {
            "allOf": [
              {
                "not": {
                  "required": [
                    "breakage_class"
                  ]
                }
              },
              {
                "not": {
                  "required": [
                    "poc_implementable"
                  ]
                }
              },
              {
                "not": {
                  "required": [
                    "poc_test_scope"
                  ]
                }
              },
              {
                "not": {
                  "required": [
                    "consensus_writeup"
                  ]
                }
              }
            ]
          }
        }
      ],
      "description": "One concrete optimization target emitted by an analyzer.\n\nConsensus-routing fields (`breakage_class`, `poc_implementable`,\n`poc_test_scope`, `consensus_writeup`) are conditionally required based\non `consensus_breaking` + `breakage_class`; see [`AnalyzerTarget::validate`]\nfor the cross-field rules.",
      "properties": {
        "breakage_class": {
          "anyOf": [
            {
              "$ref": "#/$defs/BreakageClass"
            },
            {
              "type": "null"
            }
          ],
          "description": "Required when `consensus_breaking == true`. Forbidden otherwise."
        },
        "bucket": {
          "$ref": "#/$defs/Bucket",
          "description": "Authoritative bucket classification."
        },
        "consensus_breaking": {
          "description": "True iff implementing this fix would change consensus rules.",
          "type": "boolean"
        },
        "consensus_writeup": {
          "description": "Required when `consensus_breaking == true`. Forbidden otherwise.",
          "type": [
            "string",
            "null"
          ]
        },
        "evidence": {
          "description": "Trace + code evidence.",
          "type": "string"
        },
        "expected_improvement": {
          "$ref": "#/$defs/ImprovementVector",
          "description": "Three-axis honest improvement estimate."
        },
        "files": {
          "description": "Repo-relative paths, ordered most-likely first.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "fix_signature": {
          "description": "Stable kebab-case structural-fix identifier.",
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "type": "string"
        },
        "hotspot": {
          "$ref": "#/$defs/Hotspot",
          "description": "Hotspot record (self/total wall, calls, location)."
        },
        "poc_implementable": {
          "description": "Required when `consensus_breaking == true`. Forbidden otherwise.\nForced to `false` when `breakage_class == BlockValidation`.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "poc_test_scope": {
          "description": "Required when `poc_implementable == true`. Forbidden otherwise.",
          "items": {
            "type": "string"
          },
          "type": [
            "array",
            "null"
          ]
        },
        "proposed_change": {
          "description": "Concrete proposed change.",
          "type": "string"
        },
        "risk": {
          "$ref": "#/$defs/Risk",
          "description": "Subjective risk level."
        },
        "target_span": {
          "description": "Span the optimizer should target. Must NOT be a bucket anchor or a\nnon-target entry.",
          "type": "string"
        },
        "verification_plan": {
          "description": "Verification plan (which tests must pass / what to spot-check).",
          "type": "string"
        },
        "verification_replay": {
          "anyOf": [
            {
              "$ref": "#/$defs/VerificationReplay"
            },
            {
              "type": "null"
            }
          ],
          "description": "Optional targeted-replay recipe. When present, Phase 3 bench runs\nwill replay these txids / blocks with `--repetitions` instead of\nthe session's full-range bench, dramatically shrinking per-target\nwall time. Absent → full-range fallback. See\n[`VerificationReplay`] for the hash-only emission contract."
        }
      },
      "required": [
        "target_span",
        "bucket",
        "fix_signature",
        "hotspot",
        "files",
        "evidence",
        "proposed_change",
        "expected_improvement",
        "risk",
        "verification_plan",
        "consensus_breaking"
      ],
      "type": "object"
    },
    "BreakageClass": {
      "description": "Classification of a consensus-breaking change. Required when\n`consensus_breaking == true`.",
      "oneOf": [
        {
          "const": "clarity_cost_weight",
          "description": "Recalibrating a Clarity-VM cost weight (e.g. `costs.toml`).",
          "type": "string"
        },
        {
          "const": "clarity_vm_behavior",
          "description": "Changing how the Clarity VM evaluates an opcode or function.",
          "type": "string"
        },
        {
          "const": "mining_flow",
          "description": "Block production logic (mempool ordering, tx admission, fee logic).\nExercised by stacks-bench.",
          "type": "string"
        },
        {
          "const": "block_validation",
          "description": "Block acceptance / header / signature checks. NOT exercised by\nstacks-bench — `poc_implementable` MUST be false.",
          "type": "string"
        },
        {
          "const": "marf_layout",
          "description": "MARF on-disk storage format change.",
          "type": "string"
        },
        {
          "const": "on_chain_format",
          "description": "Other consensus-relevant serialization changes.",
          "type": "string"
        }
      ]
    },
    "Bucket": {
      "description": "Work-bucket classification for a target. Determined by the nearest\n`Segment: ...` ancestor of the target span in the trace tree.",
      "oneOf": [
        {
          "const": "block_processing",
          "description": "Target lives under `Segment: Tx Execution` / `Transaction`.",
          "type": "string"
        },
        {
          "const": "block_commit",
          "description": "Target lives under one of the commit-bucket Segment anchors.",
          "type": "string"
        }
      ]
    },
    "Hotspot": {
      "additionalProperties": false,
      "description": "Hotspot record carried on every analyzer-emitted target and merged target.",
      "properties": {
        "calls": {
          "description": "Number of times the span was entered in the run.",
          "format": "int64",
          "type": "integer"
        },
        "location": {
          "description": "`file.rs:LINE` location string.",
          "type": "string"
        },
        "self_wall_us": {
          "description": "Exclusive wall time at the target span (microseconds).",
          "format": "int64",
          "type": "integer"
        },
        "span": {
          "description": "Span name as it appears in trace queries.",
          "type": "string"
        },
        "total_wall_us": {
          "description": "Inclusive wall time at the target span (self plus subtree, µs).",
          "format": "int64",
          "type": "integer"
        }
      },
      "required": [
        "span",
        "self_wall_us",
        "total_wall_us",
        "calls",
        "location"
      ],
      "type": "object"
    },
    "ImprovementVector": {
      "additionalProperties": false,
      "description": "Per-axis honest estimate of a fix's percent reduction on each value lens.\nAll three axes are required; use `0` for axes the fix doesn't move.",
      "properties": {
        "commit_time": {
          "description": "Percent reduction in commit-bucket wall time.",
          "format": "double",
          "type": "number"
        },
        "tenure_throughput": {
          "description": "Percent reduction in the binding Clarity-cost axis.",
          "format": "double",
          "type": "number"
        },
        "tx_latency": {
          "description": "Percent reduction in execution-bucket wall time.",
          "format": "double",
          "type": "number"
        }
      },
      "required": [
        "tx_latency",
        "tenure_throughput",
        "commit_time"
      ],
      "type": "object"
    },
    "LensDisposition": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "not_actionable"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "reason": {
                "not": {
                  "type": "null"
                }
              }
            },
            "required": [
              "reason"
            ]
          }
        }
      ],
      "description": "Required lens disposition on accepted analyses.",
      "properties": {
        "lens": {
          "$ref": "#/$defs/SelectionLens",
          "description": "Lens being disposed of. Must equal the analysis's `selection_lens`."
        },
        "reason": {
          "description": "Required when `status == NotActionable`; optional but allowed when\n`status == Addressed`.",
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "$ref": "#/$defs/LensDispositionStatus",
          "description": "Disposition status."
        }
      },
      "required": [
        "lens",
        "status"
      ],
      "type": "object"
    },
    "LensDispositionStatus": {
      "description": "Status of a lens disposition: either an analyzer committed at least one\ntarget on the lens (`Addressed`) or it confirmed the lens signal is real\nbut structurally unfixable (`NotActionable`).",
      "oneOf": [
        {
          "const": "addressed",
          "description": "At least one target in the analysis claims non-trivial impact on the\nlens.",
          "type": "string"
        },
        {
          "const": "not_actionable",
          "description": "Analyzer drilled in, confirmed the signal, found no structural handle.\nRequires a code-level reason in the carrying record.",
          "type": "string"
        }
      ]
    },
    "RejectedAnalysis": {
      "additionalProperties": false,
      "description": "Body of a rejected analysis.",
      "properties": {
        "family_id": {
          "description": "Family id (matches the candidate's `id`).",
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "type": "string"
        },
        "reason": {
          "description": "Code-level reason the triage signal was wrong.",
          "type": "string"
        },
        "schema_version": {
          "$ref": "#/$defs/SchemaVersionV2",
          "description": "Constant: 2."
        },
        "status": {
          "$ref": "#/$defs/RejectedStatusTag",
          "description": "Status discriminator; literal `\"rejected\"`."
        }
      },
      "required": [
        "schema_version",
        "family_id",
        "status",
        "reason"
      ],
      "type": "object"
    },
    "RejectedStatusTag": {
      "description": "Status discriminator carried on rejected analyses.",
      "oneOf": [
        {
          "const": "rejected",
          "description": "Literal `\"rejected\"`.",
          "type": "string"
        }
      ]
    },
    "Risk": {
      "description": "Subjective risk level on a proposed fix.",
      "oneOf": [
        {
          "const": "low",
          "description": "Low-risk: localized, mechanical, easily reverted.",
          "type": "string"
        },
        {
          "const": "medium",
          "description": "Medium-risk: moderate scope, well-tested area.",
          "type": "string"
        },
        {
          "const": "high",
          "description": "High-risk: cross-cutting, hard-to-verify, or touches subtle invariants.",
          "type": "string"
        }
      ]
    },
    "SchemaVersionV2": {
      "const": 2,
      "type": "integer"
    },
    "SelectionLens": {
      "description": "Selection lens — the value-axis triage promoted a candidate on, and that\nthe analyzer must dispose of explicitly. Carries through verbatim into\nmerge output and the summary.",
      "oneOf": [
        {
          "const": "tx_latency",
          "description": "Wall-time savings under execution-bucket spans.",
          "type": "string"
        },
        {
          "const": "tenure_throughput",
          "description": "Clarity-budget headroom freed (deterministic Clarity cost units).",
          "type": "string"
        },
        {
          "const": "commit_time",
          "description": "Wall-time savings under commit-bucket spans.",
          "type": "string"
        }
      ]
    },
    "VerificationReplay": {
      "additionalProperties": false,
      "description": "Per-target replay recipe — the analyzer's verification plan rendered as\nmachine-readable inputs for stacks-bench's targeted-replay modes\n(`--txid`/`--block` with `--repetitions`). Optional: absence keeps the\ncurrent full-range fallback in `bench_experiments.rs`.\n\n`txids` and `blocks` are mutually inclusive: an analyzer may emit\neither, both, or neither. When both are present, the bench coordinator\nruns separate replay phases (txid mode first, block mode second)\nagainst the same per-target binary; the per-phase results land in one\n`bench-run.json` per target.\n\nAll identifier values are 0x-prefixed 64-hex-char hashes\n([`HEX_HASH_PATTERN`]). Heights and synthetic ids are NEVER acceptable\nhere — see `feature-requests-stacks-bench.md` and the autonomous\nroadmap's Layer 1A design notes for the rationale.",
      "properties": {
        "blocks": {
          "description": "Representative stacks index block hashes the analyzer wants\nre-run. Picked from drilldown queries via the `stacks_block_hash`\n(a.k.a. `stacks_block.block_hash_hex`) column.",
          "items": {
            "pattern": "^0x[0-9a-fA-F]{64}$",
            "type": "string"
          },
          "maxItems": 16,
          "minItems": 1,
          "type": [
            "array",
            "null"
          ]
        },
        "rationale": {
          "description": "One-line explanation of why the analyzer picked txids vs blocks\nvs both (e.g. \"block-context: seal-path change needs full block\ncommit\"). Surfaced in summaries; non-actionable for the\ncoordinator.",
          "type": "string"
        },
        "repetitions": {
          "description": "Number of measured repetitions per replay target. Mapped to\n`--repetitions` on stacks-bench `bench run`. The full bench\nsubstitutes per-target replay budget for full-range wall-time.",
          "format": "uint32",
          "maximum": 200,
          "minimum": 1,
          "type": "integer"
        },
        "txids": {
          "description": "Representative transaction hashes the analyzer wants re-run.\nPicked from drilldown queries via the `tx_hash` (a.k.a.\n`stacks_tx.tx_hash_hex`) column.",
          "items": {
            "pattern": "^0x[0-9a-fA-F]{64}$",
            "type": "string"
          },
          "maxItems": 16,
          "minItems": 1,
          "type": [
            "array",
            "null"
          ]
        },
        "warmup": {
          "description": "Number of warmup repetitions discarded before measurement\nbegins. Mapped to `--warmup` on stacks-bench `bench run`.\nCold-fork single-tx / single-block replay has empty caches\n(MARF node cache, SQLite page cache, allocator state); 5-10\nwarmup reps lets caches settle into a representative-ish state\nbefore the measured reps run. Defaults to `10` when omitted;\nrecipes can override (e.g. set lower for very expensive blocks\nwhere each rep is already minutes).",
          "format": "uint32",
          "maximum": 200,
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "required": [
        "repetitions",
        "rationale"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "anyOf": [
    {
      "$ref": "#/$defs/AcceptedAnalysis",
      "description": "Analyzer drilled in; either committed targets or explicitly recorded\nthe lens as not actionable."
    },
    {
      "$ref": "#/$defs/RejectedAnalysis",
      "description": "Analyzer determined the triage signal was a false positive at code\nlevel; no targets, just a reason."
    }
  ],
  "description": "Top-level shape of `analysis.json`. Untagged: serde tries\n[`AcceptedAnalysis`] first (matches when `status: \"accepted\"`), then\n[`RejectedAnalysis`] (matches when `status: \"rejected\"`).",
  "title": "Analysis"
}
